{
  "compilerOptions": {
    "target": "ES2021",
    "module": "commonjs",
    "moduleResolution": "node",
    "rootDir": ".",
    "outDir": "dist",
    "esModuleInterop": true,
    "resolveJsonModule": true,
    "skipLibCheck": true,
    "strict": false,
    "allowJs": true,
    "checkJs": false,
    "noEmit": true,
    "types": ["node", "jest", "vitest/globals"]
  },
  "include": ["src/**/*.ts", "tests/**/*.ts", "src/**/*.js", "tests/**/*.js"],
  "exclude": ["node_modules", "dist", "coverage"]
}
