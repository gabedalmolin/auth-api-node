{
  "name": "auth-api",
  "version": "1.0.0",
  "description": "",
  "main": "index.js",
  "type": "commonjs",
  "scripts": {
    "dev": "nodemon src/server.js",
    "start": "node src/server.js",
    "pretest": "prisma migrate reset --force && prisma generate",
    "test": "vitest run --config vitest.config.mjs --pool=forks --maxWorkers=1",
    "pretest:coverage": "prisma migrate reset --force && prisma generate",
    "test:coverage": "vitest run --config vitest.config.mjs --coverage --pool=forks --maxWorkers=1",
    "lint": "biome lint .",
    "lint:fix": "biome lint . --write",
    "format": "biome check . --formatter-enabled=true --linter-enabled=false --assist-enabled=false",
    "format:write": "biome format . --write",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "typecheck:fast": "tsgo --project tsconfig.json",
    "test:vitest": "vitest run --config vitest.config.mjs --pool=forks --maxWorkers=1",
    "test:vitest:coverage": "vitest run --config vitest.config.mjs --coverage --pool=forks --maxWorkers=1",
    "pretest:vitest": "prisma migrate reset --force && prisma generate",
    "pretest:vitest:coverage": "prisma migrate reset --force && prisma generate",
    "test:jest": "jest --runInBand",
    "test:jest:coverage": "jest --runInBand --coverage"
  },
  "collectCoverageFrom": [
    "src/**/*.js",
    "!src/server.js",
    "!src/docs/**"
  ],
  "coverageThreshold": {
    "global": {
      "branches": 70,
      "functions": 80,
      "lines": 80,
      "statements": 80
    }
  },
  "keywords": [],
  "author": "",
  "license": "ISC",
  "dependencies": {
    "@prisma/adapter-pg": "^7.3.0",
    "@prisma/client": "^7.3.0",
    "bcryptjs": "^3.0.3",
    "dotenv": "^17.2.3",
    "express": "^5.2.1",
    "ioredis": "^5.9.2",
    "jsonwebtoken": "^9.0.3",
    "pg": "^8.18.0",
    "pino": "^10.3.0",
    "prisma": "^7.3.0",
    "swagger-jsdoc": "^6.2.8",
    "swagger-ui-express": "^5.0.1",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.3.14",
    "@eslint/js": "^9.39.2",
    "@types/bcryptjs": "^2.4.6",
    "@types/express": "^5.0.6",
    "@types/jest": "^30.0.0",
    "@types/jsonwebtoken": "^9.0.10",
    "@types/node": "^25.2.2",
    "@types/supertest": "^6.0.3",
    "@types/swagger-jsdoc": "^6.0.4",
    "@types/swagger-ui-express": "^4.1.8",
    "@typescript-eslint/eslint-plugin": "^8.55.0",
    "@typescript-eslint/parser": "^8.55.0",
    "@typescript/native-preview": "^7.0.0-dev.20260209.1",
    "@vitest/coverage-v8": "^4.0.18",
    "eslint": "^9.39.2",
    "eslint-config-prettier": "^10.1.8",
    "globals": "^17.3.0",
    "jest": "^30.2.0",
    "nodemon": "^3.1.11",
    "pino-pretty": "^13.1.3",
    "prettier": "^3.8.1",
    "supertest": "^7.2.2",
    "ts-jest": "^29.4.6",
    "tsx": "^4.21.0",
    "typescript": "^5.9.3",
    "vitest": "^4.0.18",
    "yaml": "^2.8.2"
  },
  "jest": {
    "clearMocks": true,
    "testEnvironment": "node",
    "setupFiles": [
      "<rootDir>/tests/jest.env.js"
    ],
    "setupFilesAfterEnv": [
      "<rootDir>/tests/setup.js"
    ]
  }
}
