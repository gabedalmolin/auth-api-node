NODE_ENV=production
PORT=3000

# Set these from your Railway PostgreSQL and Redis services.
DATABASE_URL="postgresql://replace-with-railway-postgres-url"
REDIS_URL="redis://replace-with-railway-redis-url"

ACCESS_TOKEN_SECRET="replace-with-a-strong-access-secret-of-at-least-32-characters"
REFRESH_TOKEN_SECRET="replace-with-a-strong-refresh-secret-of-at-least-32-characters"
ACCESS_TOKEN_EXPIRES_IN="15m"
REFRESH_TOKEN_EXPIRES_IN="7d"
JWT_ISSUER="auth-api"
JWT_AUDIENCE="auth-api-clients"

RATE_LIMIT_WINDOW_MS=60000
RATE_LIMIT_MAX_REQUESTS=100
LOG_LEVEL="info"
TRUST_PROXY=1
DOCS_ENABLED=true
METRICS_ENABLED=true
BCRYPT_ROUNDS=10
